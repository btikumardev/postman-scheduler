    {
      "name": "replace tag",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Read the source tag name created by 'Create Keyword' request",
              "const sourceTag = pm.collectionVariables.get(\"newly_created_tagname\");",
              "",
              "",
              "// Generate a new unique destination tag name",
              "const updatedTagName = sourceTag + \"_updated\";",
              "pm.collectionVariables.set(\"tagNameUpdated\", updatedTagName);",
              "",
              "",
              "",
              "",
              ""
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
