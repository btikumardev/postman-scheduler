    {
      "name": "Create tag",
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "// Generate a unique tag name",
              "const tagName = \"tag_\" + Date.now();",
              "",
              "// Set it as a variable to use in the request body",
              "pm.variables.set(\"tagName\", tagName);",
              "",
              "console.log(\"Generated tag name:\", tagName);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "const tagname = pm.response.json().data.name;",
              "",
              "pm.collectionVariables.set(\"newly_created_tagname\", tagname);",
              "pm.collectionVariables.set(\"tagid\", pm.response.json().data.id);",
              "",
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
